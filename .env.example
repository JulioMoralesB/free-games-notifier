# =============================================================================
# Free Games Notifier Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================================

# REQUIRED: Discord Webhook URL
# Get this from: Discord Server → Server Settings → Integrations → Webhooks
# Example: https://discord.com/api/webhooks/123456789/abcdefghijklmnopqrst
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# Optional: Epic Games API URL (defaults to official API if not provided)
# Leave commented for default behavior
# EPIC_GAMES_API_URL=https://store-site-backend-static.ak.epicgames.com/freeGamesPromotions

# Optional: Comma-separated list of stores to scrape.
# Supported values: epic, steam. Defaults to "epic" for backwards compatibility.
# Examples: ENABLED_STORES=epic  |  ENABLED_STORES=epic,steam  |  ENABLED_STORES=steam
# ENABLED_STORES=epic

# Optional: Health Check Monitoring (Healthchecks.io, UptimeKuma, etc)
# Set to your monitoring service ping URL to get alerts when notifier stops running
# HEALTHCHECK_URL=https://healthchecks.io/ping/YOUR_UUID_HERE

# Optional: Enable health check pings (true/false)
# Only enable if you've set HEALTHCHECK_URL
ENABLE_HEALTHCHECK=false

# Optional: PostgreSQL Database Configuration
# Leave all DB_* variables commented to use file-based JSON storage (default)
# If you want to use PostgreSQL, uncomment and fill in these values:

# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=free_games
# DB_USER=postgres
# DB_PASSWORD=your_secure_password

# Optional: PostgreSQL connection timeout in seconds (applies to all DB operations).
# Increase if your database server is on a slow or remote network.
# DB_CONNECT_TIMEOUT=10

# Optional: PostgreSQL connection timeout in seconds for the /health liveness check.
# Keep this lower than DB_CONNECT_TIMEOUT so health checks fail fast.
# DB_HEALTH_CHECK_TIMEOUT=5

# Optional: Timezone for date display in Discord notifications.
# Uses IANA timezone names. Derived from LANGUAGE when not set; falls back to UTC.
# Examples: America/New_York, Europe/London, Asia/Tokyo, UTC
# TIMEZONE=UTC

# Optional: Unified region setting (IANA timezone string).
# Setting this single variable configures your timezone AND derives locale,
# Epic region, Steam language, and Steam country all at once.
# Individual vars below take precedence when set explicitly.
#
# Supported values (use exactly as written):
#   America/Mexico_City · America/New_York · America/Chicago
#   America/Los_Angeles · America/Denver · America/Toronto
#   America/Sao_Paulo · America/Argentina/Buenos_Aires
#   Europe/Madrid · Europe/London · Europe/Berlin · Europe/Paris
#   Europe/Rome · Europe/Warsaw · Europe/Moscow · Europe/Istanbul
#   Europe/Lisbon · Europe/Amsterdam · Asia/Tokyo · Asia/Seoul
#   Asia/Shanghai · Australia/Sydney
#
# REGION=America/Mexico_City

# --- Individual overrides (take precedence over REGION when set) ---

# Optional: Locale for date formatting (month names, etc.)
# All locales supported by the REGION profiles are pre-installed in the Docker image.
# Defaults to the REGION-derived locale, or en_US.UTF-8 if REGION is not set.
# Examples: es_MX.UTF-8, de_DE.UTF-8, fr_FR.UTF-8
# LOCALE=en_US.UTF-8

# Optional: Epic Games region used in store links.
# Defaults to REGION when not set. Examples: es-MX, de-DE, fr-FR, pt-BR
# EPIC_GAMES_REGION=en-US

# Optional: Language for Steam game descriptions (Steam API name).
# Derived from REGION when not set.
# Full list: https://partner.steamgames.com/doc/store/localization/languages
# Examples: spanish, german, french, portuguese
# STEAM_LANGUAGE=english

# Optional: Country code for Steam store requests (controls currency in prices).
# Uses ISO 3166-1 alpha-2 codes. Derived from REGION when not set.
# Examples: MX (MXN), DE (EUR), GB (GBP), BR (BRL)
# STEAM_COUNTRY=US

# Optional: How often to check for new free games, in hours.
# When set, the service runs on a repeating interval instead of once per day.
# Recommended for multi-store setups (Steam games can appear at any time).
# Minimum value is 1 hour. Fractional values are supported (e.g. 0.5 → clamped to 1).
# Examples: 1 (every hour), 6 (every 6 hours), 12 (twice a day)
# Leave commented (or empty) to fall back to SCHEDULE_TIME (once-daily mode).
# CHECK_INTERVAL_HOURS=6

# Optional: Daily schedule time (HH:MM) at which free games are checked.
# Used only when CHECK_INTERVAL_HOURS is NOT set (once-per-day legacy mode).
# Interpreted in the timezone set by TIMEZONE above (defaults to UTC).
# Defaults to 12:00
# SCHEDULE_TIME=12:00

# Optional: Health check ping interval in minutes
# Defaults to 1 minute
# HEALTHCHECK_INTERVAL=1

# Optional: strftime format string for the promotion end date shown in Discord
# Supported codes:
#   %d  - Day of the month (01-31)
#   %B  - Full month name (e.g. January, enero) — affected by LOCALE
#   %Y  - 4-digit year (e.g. 2025)
#   %I  - Hour in 12-hour format (01-12)
#   %H  - Hour in 24-hour format (00-23)
#   %M  - Minutes (00-59)
#   %p  - AM/PM locale string — include this when using %I (12-hour clock)
# Default is English-style. Change to match your locale:
#   English default: "%B %d, %Y at %I:%M %p"  → January 31, 2025 at 03:00 PM
#   Spanish example: "%d de %B de %Y a las %I:%M %p"  → 31 de enero de 2025 a las 03:00 PM
#   24-hour example: "%d/%m/%Y %H:%M"  → 31/01/2025 15:00  (omit %p for 24-hour formats)
# DATE_FORMAT=%B %d, %Y at %I:%M %p

# Optional: API key for protecting mutating REST API endpoints (POST requests)
# If not set, no authentication is required.
# API_KEY=your_secret_api_key_here

# Optional: Host and port for the REST API server
# Defaults to 0.0.0.0:8000. Use 127.0.0.1 for local-only access.
# API_HOST=0.0.0.0
# API_PORT=8000

# =============================================================================
# Docker volume paths (used by compose.yaml bind mounts)
# Relative paths are resolved from the directory where you run docker compose.
# Change to absolute paths if you prefer a specific location on your host.
DATA_PATH=./data
LOGS_PATH=./logs

# =============================================================================
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your Discord webhook URL (minimum required)
# 3. (Optional) Add database credentials if using PostgreSQL
# 4. (Optional) Add health check URL if monitoring uptime
# 5. (Optional) Set TIMEZONE, LOCALE, EPIC_GAMES_REGION to match your region
# 6. (Optional) Set API_KEY to protect mutating API endpoints
# =============================================================================
